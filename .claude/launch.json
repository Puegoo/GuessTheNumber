{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "game",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),t={'.html':'text/html','.css':'text/css','.js':'application/javascript'};h.createServer((q,r)=>{let u=q.url.split('?')[0];if(u==='/') u='/index.html';f.readFile('.'+u,(e,d)=>{if(e){r.writeHead(404);r.end();return}r.writeHead(200,{'Content-Type':t[p.extname(u)]||'text/plain'});r.end(d)})}).listen(8090)"],
      "port": 8090
    }
  ]
}
